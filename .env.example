# Copy this file to .env and fill in real values before running
# .env is gitignored and must never be committed

POSTGRES_DB=homeplanner
POSTGRES_USER=homeplanner
POSTGRES_PASSWORD=changeme_strong_password_here
DATABASE_URL=postgresql://homeplanner:changeme_strong_password_here@db:5432/homeplanner

AI_ENABLED=true
AI_BASE_URL=http://your-litellm-host:4000
AI_API_KEY=your-key          # or leave blank
AI_VISION_MODEL=qwen2-vl:7b  # default
